# Supabase (Barn-Book project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL (used for QR codes, invite links)
NEXT_PUBLIC_SITE_URL=https://barnbook.us

# Anthropic API — server-only. Powers the Document Scanner feature.
# Never expose to the client. Not prefixed with NEXT_PUBLIC_ on purpose.
ANTHROPIC_API_KEY=your-anthropic-key
